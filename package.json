{
  "name": "wiki-hub-mcp",
  "version": "1.0.0",
  "description": "MCP server implementing Karpathy's LLM Wiki pattern. GitHub-backed persistent wiki with BM25 full-text search.",
  "author": "Karanjot Singh",
  "repository": {
    "type": "git",
    "url": "https://github.com/karanjot786/wiki-hub-mcp.git"
  },
  "homepage": "https://github.com/karanjot786/wiki-hub-mcp#readme",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "wiki-hub-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "wiki",
    "llm",
    "knowledge-base",
    "github"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "better-sqlite3": "^11.0.0",
    "gray-matter": "^4.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^25.7.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^9.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.6"
  }
}
